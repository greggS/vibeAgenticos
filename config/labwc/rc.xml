<?xml version="1.0"?>
<labwc_config>
  <keyboard>
    <keybind key="Super+Return">
      <action name="Execute">
        <command>foot</command>
      </action>
    </keybind>
    <keybind key="Super+q">
      <action name="Close" />
    </keybind>
    <!-- Super+T: toggle terminal -->
    <keybind key="Super+t">
      <action name="Execute">
        <command>sh ~/.openclaw/scripts/toggle-terminal.sh</command>
      </action>
    </keybind>
  </keyboard>

  <windowRules>
    <!-- Main AgenticOS kiosk: no decorations -->
    <windowRule title="AgenticOS" serverDecoration="no">
    </windowRule>
  </windowRules>
</labwc_config>
