<?xml version="1.0"?>
<labwc_config>
  <keyboard>
    <keybind key="Super+Return">
      <action name="Execute">
        <command>foot</command>
      </action>
    </keybind>
    <keybind key="Super+q">
      <action name="Close" />
    </keybind>
  </keyboard>

  <windowRules>
    <!-- Agents zone: no decorations, fills top 720px -->
    <windowRule title="AgenticOS — Agents Zone">
      <action name="SetDecorations" decorations="none"/>
    </windowRule>

    <!-- Prompt bar: no decorations, always on top -->
    <windowRule title="AgenticOS Prompt">
      <action name="SetDecorations" decorations="none"/>
      <action name="AlwaysOnTop"/>
    </windowRule>
  </windowRules>
</labwc_config>
