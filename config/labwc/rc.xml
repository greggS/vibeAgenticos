<?xml version="1.0"?>
<labwc_config>
  <keyboard>
    <keybind key="Super+Return">
      <action name="Execute">
        <command>foot</command>
      </action>
    </keybind>
    <keybind key="Super+q">
      <action name="Close" />
    </keybind>
    <!-- Super+T: toggle terminal -->
    <keybind key="Super+t">
      <action name="Execute">
        <command>sh ~/.openclaw/scripts/toggle-terminal.sh</command>
      </action>
    </keybind>
  </keyboard>

  <windowRules>
    <!-- Agents zone: no server-side decorations -->
    <windowRule title="AgenticOS — Agents Zone" serverDecoration="no">
    </windowRule>

    <!-- Prompt bar: no decorations, always on top, pinned to y=720 -->
    <windowRule title="AgenticOS Prompt" serverDecoration="no">
      <action name="AlwaysOnTop"/>
      <action name="Move"><x>0</x><y>720</y></action>
      <action name="Resize"><width>1280</width><height>80</height></action>
    </windowRule>
  </windowRules>
</labwc_config>
